<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Duplicate Grantee Checker</title>
  <link rel="stylesheet" href="./styles.css" />
  <script>
    window.APP_CONFIG = {
      API_BASE_URL: "https://your-render-backend.onrender.com"
    };
  </script>
</head>
<body>
  <div class="app-shell" id="appShell">
    <aside class="sidebar" id="sidebar">
      <div>
        <div class="brand">DG</div>
        <h1>Duplicate Grantee Checker</h1>
        <p>Upload name lists, review HEI-level duplicates, and manage dropdown data from the admin panel.</p>
      </div>
      <nav class="nav-links">
        <button class="nav-link active" data-view="dashboard">Dashboard</button>
        <button class="nav-link" data-view="history">History</button>
        <button class="nav-link" data-view="results">Results</button>
        <button class="nav-link admin-only hidden" data-view="admin">Admin Panel</button>
      </nav>
      <div class="sidebar-foot">
        <div class="small">Render backend · Vercel frontend · Neon DB</div>
      </div>
    </aside>

    <main class="main-content">
      <header class="topbar">
        <div class="topbar-left">
          <button class="icon-btn" id="sidebarToggle" title="Toggle sidebar">☰</button>
          <div class="api-badge" id="apiBadge">Checking API...</div>
        </div>
        <div class="topbar-actions">
          <button class="icon-btn" id="themeToggle" title="Toggle theme">◐</button>
          <button class="btn btn-secondary" id="loginToggle">Admin Login</button>
          <div class="user-pill hidden" id="userPill"></div>
        </div>
      </header>

      <section id="dashboardView">
        <section class="hero-card">
          <div>
            <span class="eyebrow">Upload workflow</span>
            <h2>Use dropdowns for metadata and upload an Excel file with name columns only.</h2>
            <p class="muted">Excel format: LastName, FirstName, MiddleName. Duplicate checking runs only within the same HEI and scholarship for the selected academic year and semester.</p>
          </div>
        </section>

        <section class="stats-grid" id="statsGrid"></section>

        <section class="grid-two">
          <div class="panel">
            <div class="panel-head">
              <div>
                <span class="eyebrow">New upload</span>
                <h3>Upload checker</h3>
              </div>
            </div>
            <form class="upload-form" id="uploadForm">
              <div class="form-grid">
                <label>
                  <span>HEI</span>
                  <select class="select-input" id="heiSelect" required></select>
                </label>
                <label>
                  <span>Scholarship</span>
                  <select class="select-input" id="scholarshipSelect" required></select>
                </label>
                <label>
                  <span>Academic Year</span>
                  <select class="select-input" id="academicYearSelect" required></select>
                </label>
                <label>
                  <span>Semester</span>
                  <select class="select-input" id="semesterSelect" required></select>
                </label>
                <label>
                  <span>Batch</span>
                  <select class="select-input" id="batchSelect" required></select>
                </label>
              </div>
              <div class="hint-box">Required Excel columns: LastName, FirstName, MiddleName</div>
              <input class="file-input" type="file" id="fileInput" accept=".xlsx,.xls" required />
              <button class="btn" type="submit">Upload and check duplicates</button>
              <p class="form-message" id="uploadMessage"></p>
            </form>
          </div>

          <div class="panel">
            <div class="panel-head">
              <div>
                <span class="eyebrow">Recent uploads</span>
                <h3>Latest activity</h3>
              </div>
            </div>
            <div class="table-wrap compact-table">
              <table>
                <thead>
                  <tr>
                    <th>Upload</th>
                    <th>Status</th>
                    <th>Uploaded</th>
                    <th>Action</th>
                  </tr>
                </thead>
                <tbody id="recentUploadsBody"></tbody>
              </table>
            </div>
          </div>
        </section>
      </section>

      <section id="historyView" class="hidden">
        <section class="panel">
          <div class="panel-head">
            <div>
              <span class="eyebrow">Upload history</span>
              <h2>Saved checks</h2>
            </div>
          </div>
          <div class="toolbar toolbar-wrap">
            <input class="search-input" id="historySearch" placeholder="Search HEI, scholarship, AY, semester, or batch" />
          </div>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>#</th>
                  <th>Upload</th>
                  <th>Status</th>
                  <th>Uploaded</th>
                  <th>Rows</th>
                  <th>Duplicates</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody id="historyBody"></tbody>
            </table>
          </div>
        </section>
      </section>

      <section id="resultsView" class="hidden">
        <section class="hero-card">
          <div>
            <span class="eyebrow">Result set</span>
            <h2 id="resultsTitle">Results</h2>
            <p class="muted" id="resultsMeta"></p>
          </div>
        </section>
        <section class="stats-grid mini-grid" id="resultSummaryCards"></section>
        <section class="panel">
          <div class="panel-head">
            <div>
              <span class="eyebrow">Filters</span>
              <h3>Review flagged rows</h3>
            </div>
          </div>
          <div class="toolbar toolbar-wrap">
            <input class="search-input" id="resultSearch" placeholder="Search name, matched name, batch" />
            <label class="toggle"><input type="checkbox" id="duplicatesOnly" checked /> Duplicates only</label>
            <select class="select-input narrow" id="matchTypeFilter">
              <option value="all">All match types</option>
              <option value="exact_duplicate">Exact duplicate</option>
              <option value="possible_duplicate">Possible duplicate</option>
              <option value="clean">Clean only</option>
            </select>
          </div>
          <div class="match-summary" id="matchSummary"></div>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>#</th>
                  <th>Full name</th>
                  <th>HEI</th>
                  <th>Scholarship</th>
                  <th>Batch</th>
                  <th>Status</th>
                  <th>Matched name</th>
                  <th>Matched batch</th>
                  <th>Score</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody id="resultsBody"></tbody>
            </table>
          </div>
        </section>
      </section>

      <section id="adminView" class="hidden">
        <section class="panel">
          <div class="panel-head">
            <div>
              <span class="eyebrow">Admin only</span>
              <h2>Manage dropdown values</h2>
            </div>
          </div>
          <div class="admin-grid" id="adminGrid"></div>
        </section>
      </section>
    </main>
  </div>

  <div class="modal-backdrop hidden" id="loginModal">
    <div class="modal-card small-modal">
      <div class="modal-head">
        <h3>Admin Login</h3>
        <button class="icon-btn" data-close-modal="loginModal">✕</button>
      </div>
      <form id="loginForm" class="upload-form compact-form">
        <label><span>Username</span><input class="search-input" id="loginUsername" required /></label>
        <label><span>Password</span><input class="search-input" id="loginPassword" type="password" required /></label>
        <button class="btn" type="submit">Sign in</button>
        <p class="form-message" id="loginMessage"></p>
      </form>
    </div>
  </div>

  <div class="modal-backdrop hidden" id="matchModal">
    <div class="modal-card">
      <div class="modal-head">
        <div>
          <span class="eyebrow">Matched record</span>
          <h3>Side-by-side comparison</h3>
        </div>
        <button class="icon-btn" data-close-modal="matchModal">✕</button>
      </div>
      <div class="compare-grid" id="matchModalBody"></div>
    </div>
  </div>

  <script src="./app.js"></script>
</body>
</html>
